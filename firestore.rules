rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/modules/{moduleId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/exams/{examId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/friends/{friendId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/gradeglow/{documentId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /publicStudyProfiles/{profileId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == profileId;
      allow delete: if request.auth != null && request.auth.uid == profileId;
    }

    match /studyFriendCodes/{codeId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.normalizedCode == codeId;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Manual Premium / Admin rights live here.
    // Clients can read their own entitlement but cannot write it.
    // Create or edit these documents manually in Firebase Console or later via Stripe/Paddle webhooks.
    match /entitlements/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }
}
