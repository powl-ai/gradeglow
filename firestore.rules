rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/entitlements/$(request.auth.uid))
        && get(/databases/$(database)/documents/entitlements/$(request.auth.uid)).data.plan == "admin";
    }

    function protectedPremiumFields() {
      return [
        "plan",
        "isPremium",
        "premiumStatus",
        "premiumSource",
        "premiumExpiresAt",
        "premiumUntil",
        "betaTester",
        "role"
      ];
    }

    function validFeedbackType() {
      return request.resource.data.type in ["bug", "feedback", "feature_request", "delete_request", "beta_note"];
    }

    function validFeedbackPriority() {
      return request.resource.data.priority in ["low", "normal", "high"];
    }

    function validFeedbackStatus() {
      return request.resource.data.status in ["open", "reviewing", "planned", "done", "closed"];
    }

    function validDiagnosticKind() {
      return request.resource.data.kind in ["bug_report", "client_error", "ui_audit", "system_check"];
    }

    function validDiagnosticPriority() {
      return request.resource.data.priority in ["low", "normal", "high", "critical"];
    }

    function validDiagnosticStatus() {
      return request.resource.data.status in ["open", "reviewing", "fixed", "ignored", "closed"];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && !request.resource.data.keys().hasAny(protectedPremiumFields());

      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedPremiumFields());

      allow delete: if isOwner(userId)
        && !resource.data.keys().hasAny(protectedPremiumFields());
    }

    match /users/{userId}/modules/{moduleId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/exams/{examId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/schedule/{scheduleId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/friends/{friendId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create, update: if isOwner(userId)
        || isAdmin()
        || (isSignedIn()
          && request.auth.uid == friendId
          && request.resource.data.uid == friendId
          && request.resource.data.mutualWith == userId);

      allow delete: if isOwner(userId)
        || isAdmin()
        || (isSignedIn() && request.auth.uid == friendId && resource.data.uid == friendId);
    }

    match /users/{userId}/studyCircles/{circleId} {
      allow read, create, update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId)
        || isAdmin()
        || (isSignedIn()
          && get(/databases/$(database)/documents/studyCircles/$(circleId)).data.ownerUid == request.auth.uid);
    }

    match /users/{userId}/gradeglow/{documentId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/notificationSettings/{documentId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId)
        && documentId == "main"
        && request.resource.data.ownerUid == userId;
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/notificationTokens/{tokenId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId)
        && request.resource.data.uid == userId;
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read, update, delete: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
    }

    match /publicStudyProfiles/{profileId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == profileId;
      allow delete: if isSignedIn() && (request.auth.uid == profileId || isAdmin());
    }

    match /studyFriendCodes/{codeId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.normalizedCode == codeId;
      allow delete: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
    }


    match /studyCircles/{circleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.id == circleId;
      allow update, delete: if isSignedIn()
        && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    match /studyCircles/{circleId}/members/{memberId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && (request.auth.uid == memberId || isAdmin())
        && request.resource.data.uid == memberId;
      allow delete: if isSignedIn()
        && (request.auth.uid == memberId
          || isAdmin()
          || get(/databases/$(database)/documents/studyCircles/$(circleId)).data.ownerUid == request.auth.uid);
    }

    match /studyCircleCodes/{codeId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.normalizedCode == codeId;
      allow delete: if isSignedIn() && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    match /studyActivityEvents/{profileId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.auth.uid == profileId
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && (request.auth.uid == profileId || isAdmin());
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && validFeedbackType()
        && validFeedbackPriority()
        && request.resource.data.status == "open"
        && request.resource.data.subject is string
        && request.resource.data.message is string;

      allow read: if isAdmin() || (isSignedIn() && resource.data.ownerUid == request.auth.uid);

      allow update: if isAdmin()
        && validFeedbackStatus();

      allow delete: if isAdmin() || (isSignedIn() && resource.data.ownerUid == request.auth.uid);
    }

    match /diagnostics/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && validDiagnosticKind()
        && validDiagnosticPriority()
        && request.resource.data.status == "open"
        && request.resource.data.title is string
        && request.resource.data.message is string;

      allow read: if isAdmin() || (isSignedIn() && resource.data.ownerUid == request.auth.uid);

      allow update: if isAdmin()
        && validDiagnosticStatus();

      allow delete: if isAdmin() || (isSignedIn() && resource.data.ownerUid == request.auth.uid);
    }

    // Manual Premium / Admin rights live here.
    // First admin must be created manually in Firebase Console:
    // entitlements/{yourAuthUid} -> plan: "admin".
    match /entitlements/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /appConfig/{documentId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
